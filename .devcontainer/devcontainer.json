{
  "name": "Django + doit + DuckDB",
  // Attach to the 'devcontainer' service in docker-compose.yml so this
  // container shares app-network with db, redis, and rustfs.
  "dockerComposeFile": [
    "../docker-compose.yml"
  ],
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "forwardPorts": [
    8000,
    5432,
    6379,
    9000,
    5555
  ],
  "portsAttributes": {
    "8000": {
      "label": "Django"
    },
    "5432": {
      "label": "PostgreSQL"
    },
    "6379": {
      "label": "Redis"
    },
    "9000": {
      "label": "RustFS (S3)"
    },
    "5555": {
      "label": "Flower (Celery)"
    }
  },
  // Runs once after the container is created (dependencies, DB, S3 buckets).
  "postCreateCommand": "just install && just migrate && just setup-rustfs",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "batisteo.vscode-django",
        "duckdb.duckdb-vscode",
        "bradlc.vscode-tailwindcss",
        "formulahendry.auto-rename-tag",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "backend/apps"
        ],
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        },
        "jupyter.notebookFileRoot": "${workspaceFolder}",
        "files.associations": {
          "**/*.html": "django-html"
        }
      }
    }
  },
  "remoteUser": "vscode"
}