{
  "name": "Django + doit + DuckDB",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",
  "workspaceFolder": "/workspace",
  "forwardPorts": [8000, 5432, 6379, 9000, 5555],
  "portsAttributes": {
    "8000": {"label": "Django"},
    "5432": {"label": "PostgreSQL"},
    "6379": {"label": "Redis"},
    "9000": {"label": "RustFS (S3)"},
    "5555": {"label": "Flower (Celery)"}
  },
  "postCreateCommand": "just install && just migrate && just setup-rustfs",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "batisteo.vscode-django",
        "duckdb.duckdb-vscode",
        "bradlc.vscode-tailwindcss",
        "formulahendry.auto-rename-tag",
        "charliermarsh.ruff"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": ["backend/apps"],
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        },
        "jupyter.notebookFileRoot": "${workspaceFolder}",
        "jupyter.kernels.filter": [
          {
            "path": "/usr/local/bin/python",
            "type": "pythonEnvironment"
          }
        ],
        "djlint.useVenv": false,
        "files.associations": {
          "**/*.html": "django-html"
        }
      }
    }
  },
  "mounts": [
    "source=${localWorkspaceFolder}/data,target=/workspace/data,type=bind,consistency=cached"
  ],
  "remoteUser": "vscode"
}
