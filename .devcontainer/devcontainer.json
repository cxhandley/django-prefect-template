{
  "name": "Django + doit + DuckDB",
  "dockerComposeFile": [
    "../docker-compose.yml"
  ],
  "service": "devcontainer",
  "workspaceFolder": "/workspace",
  "forwardPorts": [
    8000,
    5432,
    6379,
    9000,
    5555,
    8080
  ],
  "portsAttributes": {
    "8000": {
      "label": "Django"
    },
    "5432": {
      "label": "PostgreSQL"
    },
    "6379": {
      "label": "Redis"
    },
    "9000": {
      "label": "RustFS (S3)"
    },
    "5555": {
      "label": "Flower (Celery)"
    },
    "8080": {
      "label": "Mojo Compute"
    }
  },
  "mounts": [
    "source=${localEnv:USERPROFILE}/.claude,target=/home/vscode/.claude,type=bind",
    "source=${localEnv:USERPROFILE}/.gitconfig,target=/home/vscode/.gitconfig,type=bind,readonly"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "batisteo.vscode-django",
        "duckdb.duckdb-vscode",
        "bradlc.vscode-tailwindcss",
        "formulahendry.auto-rename-tag",
        "charliermarsh.ruff",
        "anthropic.claude-code",
        "modular-mojotools.vscode-mojo"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/venv/bin/python",
        "python.testing.pytestEnabled": true,
        "python.testing.pytestArgs": [
          "backend/apps"
        ],
        "editor.formatOnSave": true,
        "[python]": {
          "editor.defaultFormatter": "charliermarsh.ruff"
        },
        "jupyter.notebookFileRoot": "${workspaceFolder}",
        "files.associations": {
          "**/*.html": "django-html"
        }
      }
    }
  },
  "remoteUser": "vscode",
  "postCreateCommand": "bash .devcontainer/post-create.sh"
}
