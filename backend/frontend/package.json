{
  "name": "django-doit-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "npm run build:css && npm run vendor:htmx",
    "build:css": "tailwindcss -i src/main.css -o ../static/dist/main.css --minify",
    "watch": "tailwindcss -i src/main.css -o ../static/dist/main.css --watch",
    "vendor:htmx": "cp node_modules/htmx.org/dist/htmx.min.js ../static/vendor/htmx.min.js"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.1.0",
    "tailwindcss": "^4.1.0"
  },
  "dependencies": {
    "daisyui": "^5.0.0",
    "htmx.org": "^2.0.4"
  }
}
