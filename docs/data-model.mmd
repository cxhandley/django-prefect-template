erDiagram
    %% ============================================
    %% IMPLEMENTED — reflects backend/apps/flows/models.py
    %% Django's built-in User model is used for authentication
    %% ============================================

    USER {
        int id PK
        string email UK
        string username
        string password "hashed"
        boolean is_active
        boolean is_staff
        boolean is_superuser
        datetime date_joined
        datetime last_login
    }

    FLOW_EXECUTION {
        int id PK
        uuid flow_run_id UK "unique execution identifier"
        string flow_name "e.g. pipeline | predict_pipeline"
        int triggered_by_id FK "references USER"
        string s3_input_path "S3 key for uploaded file"
        string s3_output_path "S3 key for output parquet"
        bigint row_count "populated after completion"
        decimal file_size_mb
        string status "PENDING|RUNNING|COMPLETED|FAILED"
        json parameters "execution params + prediction results"
        string celery_task_id "for task revocation"
        text error_message
        datetime created_at
        datetime completed_at
    }

    USER_PROFILE {
        int id PK
        int user_id FK "OneToOne → USER"
        boolean notify_on_failure "default true"
    }

    INPUT_PRESET {
        int id PK
        int user_id FK "references USER"
        string name "user-defined label"
        json input_values "prediction field values"
        datetime created_at
    }

    USER ||--o{ FLOW_EXECUTION : "triggers"
    USER ||--|| USER_PROFILE : "has"
    USER ||--o{ INPUT_PRESET : "owns"

