erDiagram
    %% ============================================
    %% IMPLEMENTED — reflects backend/apps/flows/models.py
    %% Django's built-in User model is used for authentication
    %% ============================================

    USER {
        int id PK
        string email UK
        string username
        string password "hashed"
        boolean is_active
        boolean is_staff
        boolean is_superuser
        datetime date_joined
        datetime last_login
    }

    FLOW_EXECUTION {
        int id PK
        uuid flow_run_id UK "unique execution identifier"
        string flow_name "e.g. pipeline | predict_pipeline"
        int triggered_by_id FK "references USER"
        string s3_input_path "S3 key for uploaded file"
        string s3_output_path "S3 key for output parquet"
        bigint row_count "populated after completion"
        decimal file_size_mb
        string status "PENDING|RUNNING|COMPLETED|FAILED"
        json parameters "execution params + prediction results"
        string celery_task_id "for task revocation"
        text error_message
        datetime created_at
        datetime completed_at
    }

    USER_PROFILE {
        int id PK
        int user_id FK "OneToOne → USER"
        boolean notify_on_failure "default true"
        boolean notify_on_success "default false"
        boolean notify_in_app "default true"
        boolean notify_via_email "default true"
    }

    INPUT_PRESET {
        int id PK
        int user_id FK "references USER"
        string name "user-defined label"
        json input_values "prediction field values"
        datetime created_at
    }

    NOTIFICATION {
        int id PK
        int user_id FK "references USER"
        string notification_type "EXECUTION_FAILED|EXECUTION_COMPLETED|SYSTEM"
        text message
        int related_execution_id FK "nullable → FLOW_EXECUTION"
        boolean is_read "default false"
        datetime created_at
    }

    FEATURE_FLAG {
        int id PK
        string name UK "slug"
        text description
        boolean is_enabled "global on/off fallback"
        smallint rollout_percentage "0–100; 0 = disabled"
    }

    FEATURE_FLAG_USERS {
        int featureflag_id FK
        int user_id FK
    }

    USER ||--o{ FLOW_EXECUTION : "triggers"
    USER ||--|| USER_PROFILE : "has"
    USER ||--o{ INPUT_PRESET : "owns"
    USER ||--o{ NOTIFICATION : "receives"
    FLOW_EXECUTION |o--o{ NOTIFICATION : "referenced by"
    FEATURE_FLAG ||--o{ FEATURE_FLAG_USERS : "enabled for"
    USER ||--o{ FEATURE_FLAG_USERS : "included in"

