erDiagram
    %% ============================================
    %% IMPLEMENTED — reflects backend/apps/flows/models.py
    %% Django's built-in User model is used for authentication
    %% ============================================

    USER {
        int id PK
        string email UK
        string username
        string password "hashed"
        boolean is_active
        boolean is_staff
        boolean is_superuser
        datetime date_joined
        datetime last_login
    }

    FLOW_EXECUTION {
        int id PK
        uuid flow_run_id UK "unique execution identifier"
        string flow_name "e.g. data-processing | credit-prediction"
        int triggered_by_id FK "references USER"
        string s3_input_path "S3 key for uploaded file"
        string s3_output_path "S3 key for output parquet"
        bigint row_count "populated after completion"
        decimal file_size_mb
        string status "PENDING|RUNNING|COMPLETED|FAILED (TextChoices)"
        float income "credit-prediction input — null for pipeline flows"
        int age "credit-prediction input — null for pipeline flows"
        int credit_score "credit-prediction input — null for pipeline flows"
        float employment_years "credit-prediction input — null for pipeline flows"
        json parameters "legacy blob — do not add new keys"
        string celery_task_id "for task revocation"
        text error_message
        datetime created_at
        datetime completed_at
    }

    PREDICTION_RESULT {
        int id PK
        int execution_id FK "OneToOne → FLOW_EXECUTION"
        int scoring_model_id FK "nullable → SCORING_MODEL"
        float score "weighted composite score 0–1"
        string classification "Approved|Review|Declined"
        float confidence "score * 100"
        datetime scored_at
    }

    SCORING_MODEL {
        int id PK
        string version UK "e.g. 1.0"
        text description
        json weights "factor weights e.g. {credit_score: 0.40, income: 0.30, ...}"
        json thresholds "classification thresholds e.g. {approved: 0.70, review: 0.50}"
        boolean is_active "only one active model at a time"
        datetime created_at
        int created_by_id FK "nullable → USER"
    }

    EXECUTION_STEP {
        int id PK
        int execution_id FK "references FLOW_EXECUTION"
        string step_name "e.g. ingest | validate | transform | aggregate"
        smallint step_index "0-based step order"
        string status "PENDING|RUNNING|COMPLETED|FAILED"
        datetime started_at
        datetime completed_at
        string output_s3_path
        text error_message
    }

    USER_PROFILE {
        int id PK
        int user_id FK "OneToOne → USER"
        boolean notify_on_failure "default true"
        boolean notify_on_success "default false"
        boolean notify_in_app "default true"
        boolean notify_via_email "default true"
        int mcp_token_budget "nullable; overrides MCP_SESSION_TOKEN_BUDGET setting"
    }

    INPUT_PRESET {
        int id PK
        int user_id FK "references USER"
        string name "user-defined label"
        json input_values "prediction field values"
        datetime created_at
    }

    NOTIFICATION {
        int id PK
        int user_id FK "references USER"
        string notification_type "EXECUTION_FAILED|EXECUTION_COMPLETED|SYSTEM"
        text message
        int related_execution_id FK "nullable → FLOW_EXECUTION"
        boolean is_read "default false"
        datetime created_at
    }

    FEATURE_FLAG {
        int id PK
        string name UK "slug"
        text description
        boolean is_enabled "global on/off fallback"
        smallint rollout_percentage "0–100; 0 = disabled"
    }

    FEATURE_FLAG_USERS {
        int featureflag_id FK
        int user_id FK
    }

    USER_API_KEY {
        int id PK
        int user_id FK "references USER"
        string provider "ANTHROPIC|LLAMA_OPENAI (TextChoices)"
        text encrypted_key "Fernet-encrypted; write-only after save"
        string base_url "nullable; required for LLAMA_OPENAI"
        string label "user-defined name e.g. My Anthropic key"
        boolean is_active "default true"
        datetime created_at
        datetime updated_at
    }

    USER ||--o{ FLOW_EXECUTION : "triggers"
    USER ||--|| USER_PROFILE : "has"
    USER ||--o{ INPUT_PRESET : "owns"
    USER ||--o{ NOTIFICATION : "receives"
    USER ||--o{ SCORING_MODEL : "creates"
    USER ||--o{ USER_API_KEY : "owns"
    FLOW_EXECUTION ||--o| PREDICTION_RESULT : "has result"
    FLOW_EXECUTION ||--o{ EXECUTION_STEP : "has steps"
    FLOW_EXECUTION |o--o{ NOTIFICATION : "referenced by"
    PREDICTION_RESULT }o--o| SCORING_MODEL : "scored by"
    FEATURE_FLAG ||--o{ FEATURE_FLAG_USERS : "enabled for"
    USER ||--o{ FEATURE_FLAG_USERS : "included in"

    %% ============================================
