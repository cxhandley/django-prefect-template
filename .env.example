# ─────────────────────────────────────────────────────────────────────────────
# Local dev (running Django/Celery on the host): localhost values below work.
# Inside DevContainer / docker-compose services: docker-compose.yml overrides
# the host-specific URLs (DATABASE_URL, REDIS_URL, AWS_S3_ENDPOINT_URL, etc.)
# with Docker service names automatically — no manual changes needed.
# ─────────────────────────────────────────────────────────────────────────────

# Django
DJANGO_SECRET_KEY=your-secret-key-change-in-production
DJANGO_DEBUG=True
DJANGO_SETTINGS_MODULE=config.settings.development
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,web

# Database (PostgreSQL 18)
DATABASE_URL=postgresql://django:django_password@localhost:5432/django_prefect

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# RustFS (local S3-compatible storage)
AWS_ACCESS_KEY_ID=rustfs
AWS_SECRET_ACCESS_KEY=rustfs_secret
AWS_S3_REGION=us-east-1
DATA_LAKE_BUCKET=django-prefect-datalake-dev
AWS_S3_ENDPOINT_URL=http://localhost:9000

# DuckDB
DUCKDB_THREADS=4
DUCKDB_MEMORY_LIMIT=4GB

# Notebooks
NOTEBOOKS_DIR=notebooks
NOTEBOOK_OUTPUT_DIR=data/notebook_outputs

# Email (Mailhog — SMTP sink for dev, web UI at http://localhost:8025)
# docker-compose.yml overrides these to the mailhog service name inside Docker.
EMAIL_HOST=localhost
EMAIL_PORT=1025

# Python
PYTHONUNBUFFERED=1

# Conversational Dashboard Builder (BL-038)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=
MCP_INTERNAL_SECRET=change-me-in-production
MCP_SESSION_TOKEN_BUDGET=32000
MCP_SERVER_URL=http://localhost:8001
